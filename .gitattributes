# 全体: 自動判定 + コミット時 LF 統一
* text=auto eol=lf

# テキスト系
*.kt        text eol=lf
*.kts       text eol=lf
*.java      text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.gradle    text eol=lf

# シェル: 必ず LF
*.sh        text eol=lf

# Windows バッチ: CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# バイナリ
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.svg       text eol=lf
*.pdf       binary
*.zip       binary
*.jar       binary
*.aar       binary
*.apk       binary
*.aab       binary
*.jks       binary
*.keystore  binary

# linguist (GitHub 言語統計のノイズ除去)
gradle/wrapper/** linguist-vendored
**/build/**       linguist-generated
