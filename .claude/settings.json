{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(./gradlew assembleDebug)",
      "Bash(./gradlew assembleDebug *)",
      "Bash(./gradlew :*:assemble)",
      "Bash(./gradlew :*:assembleDebug)",
      "Bash(./gradlew test)",
      "Bash(./gradlew :*:test)",
      "Bash(./gradlew detekt)",
      "Bash(./gradlew spotlessApply)",
      "Bash(./gradlew spotlessCheck)",
      "Bash(./gradlew clean)",
      "Bash(./gradlew tasks)",
      "Bash(./gradlew projects)",
      "Bash(./gradlew dependencies)",
      "Bash(./gradlew :*:dependencies)",
      "Bash(./gradlew help)",
      "Bash(./gradlew --version)",
      "Bash(./gradlew --status)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git commit -m *)",
      "Bash(git commit -am *)",
      "Bash(git tag *)",
      "Bash(git merge --no-ff *)",
      "Bash(git rebase *)",
      "Bash(git reset --soft *)",
      "Bash(git reset HEAD *)",
      "Bash(bash scripts/phase-start.sh *)",
      "Bash(bash scripts/phase-finish.sh *)",
      "Bash(rg *)",
      "Bash(grep -n *)",
      "Bash(grep -rn *)",
      "Bash(find . -type f *)",
      "Bash(find . -name *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(mkdir -p *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(printf *)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git remote add *)",
      "Bash(git remote remove *)",
      "Bash(git remote set-url *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf .git*)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(./gradlew publish*)",
      "Bash(./gradlew bundleRelease*)",
      "Bash(./gradlew assembleRelease*)",
      "Bash(adb install *)",
      "Bash(adb uninstall *)",
      "Read(./local.properties)",
      "Read(./**/*.jks)",
      "Read(./**/*.keystore)",
      "Read(./**/google-services.json)"
    ]
  },
  "env": {
    "FOLDEX_PROJECT": "true"
  }
}
